// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentType {
  BUSINESS_PROBLEM
  BUSINESS_SOLUTION_CONCEPT
  BUSINESS_SOLUTION_SPEC
  TECHNICAL_DESIGN_FRONTEND
  TECHNICAL_DESIGN_BACKEND
  TEST_VERIFICATION
  QA_BENCHMARKS
  USER_MANUAL
  RELEASE_DOCUMENT
}

model Document {
  id          String       @id @default(cuid())
  title       String
  type        DocumentType
  content     String?      @db.Text // For manually prepared text/markdown
  fileUrl     String?      // Stored static URL (fallback)
  fileKey     String?      // S3 Key for presigned URL generation
  externalLink String?     // For linked external docs
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([type])
}
