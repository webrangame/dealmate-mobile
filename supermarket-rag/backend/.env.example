# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/dbname

# LiteLLM Configuration (Gemini/Gateway)
LITELLM_API_KEY=sk-your-master-key
LITELLM_API_BASE=https://your-litellm-proxy.com

# CORS Configuration
# Comma-separated list of allowed origins. Leave empty or use "*" for development/mobile.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
# Secret key for JWT or specific security tokens if needed
SECRET_KEY=your-secret-key

# AWS S3 Configuration (for product images)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=supermarket-catalog-images
CLOUDFRONT_DOMAIN=optional-cloudfront-domain.cloudfront.net
